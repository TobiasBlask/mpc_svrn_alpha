# MPC Private Access POC environment
# Copy to .env.poc locally only. Do not commit real values.

# Polygon Amoy
POLYGON_AMOY_CHAIN_ID=80002
POLYGON_AMOY_RPC_URL=https://polygon-amoy.drpc.org
POLYGON_AMOY_EXPLORER_URL=https://amoy.polygonscan.com
POLYGONSCAN_API_URL=https://api-amoy.polygonscan.com/api
POLYGONSCAN_API_KEY=

# Deployment wallet
# Use a testnet-only wallet with no mainnet funds.
POC_DEPLOYER_PRIVATE_KEY=
POC_DEPLOYER_ADDRESS=

# WalletConnect / Reown
WALLETCONNECT_PROJECT_ID=

# Optional sandbox database for later POC backend work
DATABASE_URL=

# Optional GitHub repository once we create/link one
GITHUB_REPOSITORY=
